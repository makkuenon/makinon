<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE storyboard PUBLIC "-//Apple//DTD STORYBOARD 1.0//EN"
 "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<storyboard version="1.0" toolsVersion="20000" targetRuntime="iOS.CocoaTouch" initialViewController="MainVC">
    <scenes>
        <scene sceneID="SceneMain">
            <objects>
                <viewController id="MainVC" customClass="RootViewController" sceneMemberID="viewController">
                    <view key="view" contentMode="scaleToFill" id="MainView">
                        <rect key="frame" x="0" y="0" width="375" height="667"/>
                        <color key="backgroundColor" systemColor="systemBackgroundColor"/>
                    </view>
                </viewController>
                <placeholder placeholderIdentifier="IBFirstResponder" id="Responder" sceneMemberID="firstResponder"/>
            </objects>
        </scene>
    </scenes>
</storyboard>
